<div id="confirm-modal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="confirm-modal-title">
    <div class="modal confirm-dialog">
        <div class="modal-header">
            <h3 class="modal-title" id="confirm-modal-title">Confirmation</h3>
        </div>
        <div class="modal-body">
            <p id="confirm-modal-message" class="confirm-message"></p>
        </div>
        <div class="modal-footer">
            <button id="confirm-modal-cancel" class="btn" type="button">Annuler</button>
            <button id="confirm-modal-ok"     class="btn btn-danger" type="button">Confirmer</button>
        </div>
    </div>
</div>
