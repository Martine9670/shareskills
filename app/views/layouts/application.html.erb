<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShareSkills — Échange de Compétences</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⚛️</text></svg>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
</head>
<body>

<% if logged_in? %>
    <!-- Navigation desktop -->
    <nav class="navbar">
        <div class="nav-content">
            <%= link_to dashboard_path, class: "logo" do %>
                <div class="logo-icon">🧬</div>
                <span class="logo-text">ShareSkills</span>
            <% end %>

            <div class="nav-links">
                <%= link_to "Tableau de bord", dashboard_path, id: "nav-dashboard", class: "nav-btn #{'active' unless params[:search].present? || params[:category].present? || params[:view].present? || controller_name == 'messages'}", onclick: "if(document.getElementById('view-dashboard')){event.preventDefault();showView('dashboard')}" %>
                <%= link_to "Rechercher", dashboard_path(view: "search"), id: "nav-search", class: "nav-btn #{'active' if params[:search].present? || params[:category].present? || params[:view] == 'search'}", onclick: "if(document.getElementById('view-search')){event.preventDefault();showView('search')}" %>
                <%= link_to "Mon Profil", dashboard_path(view: "profile"), id: "nav-profile", class: "nav-btn #{'active' if controller_name == 'users' || params[:view] == 'profile'}", onclick: "if(document.getElementById('view-profile')){event.preventDefault();showView('profile')}" %>
                <% unread = Message.unread_for(current_user).count %>
                <%= link_to messages_path, class: "nav-btn #{'active' if controller_name == 'messages'}" do %>
                    ✉ Messages<% if unread > 0 %><span class="nav-badge"><%= unread %></span><% end %>
                <% end %>
                <% if current_user.is_admin? %>
                    <%= link_to "⚙ Admin", admin_root_path, class: "nav-btn nav-btn-admin" %>
                <% end %>
            </div>

            <div class="nav-right">
                <div class="credit-badge">
                    <span>⏱</span>
                    <span><%= current_user.credits_minutes %> min</span>
                </div>
                <img src="<%= current_user.avatar_url %>" alt="<%= current_user.name %>" class="avatar"
                     onclick="showView('profile')">
                <%= button_to "Déconnexion", logout_path, method: :delete, class: "nav-btn" %>
            </div>
        </div>
    </nav>

    <!-- Navigation mobile -->
    <nav class="mobile-nav">
        <%= link_to dashboard_path, class: "mobile-btn #{'active' unless params[:search].present? || params[:category].present? || params[:view] == 'search' || controller_name == 'messages'}", onclick: "if(document.getElementById('view-dashboard')){event.preventDefault();showView('dashboard')}" do %>
            <span>📊</span><span>Accueil</span>
        <% end %>
        <%= link_to dashboard_path(view: "search"), class: "mobile-btn #{'active' if params[:search].present? || params[:category].present? || params[:view] == 'search'}", onclick: "if(document.getElementById('view-search')){event.preventDefault();showView('search')}" do %>
            <span>🔍</span><span>Rechercher</span>
        <% end %>
        <%= link_to dashboard_path(view: "profile"), class: "mobile-btn #{'active' if controller_name == 'users' || params[:view] == 'profile'}", onclick: "if(document.getElementById('view-profile')){event.preventDefault();showView('profile')}" do %>
            <span>👤</span><span>Profil</span>
        <% end %>
        <%= link_to messages_path, class: "mobile-btn #{'active' if controller_name == 'messages'}" do %>
            <span>✉</span><span>Messages</span>
        <% end %>
    </nav>
<% end %>

    <!-- Flash messages -->
    <% if flash[:notice] %>
        <div class="flash flash-notice"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
        <div class="flash flash-alert"><%= flash[:alert] %></div>
    <% end %>

    <!-- Contenu principal -->
    <% if logged_in? %>
        <main class="container">
            <%= yield %>
        </main>
    <% else %>
        <main>
            <%= yield %>
        </main>
    <% end %>

    <%= render "layouts/footer" %>
    <%= render "layouts/confirm_modal" %>

</body>
</html>
