<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">
            <div class="logo-icon">S</div>
            <span class="logo-text">SkillSwap</span>
        </div>
        <h2 class="auth-title">Créer un compte</h2>

        <% if @user.errors.any? %>
            <div class="flash flash-alert">
                <% @user.errors.full_messages.each do |msg| %>
                    <p><%= msg %></p>
                <% end %>
            </div>
        <% end %>

        <%= form_with model: @user, url: signup_path do |f| %>
            <div class="form-group">
                <%= f.label :name, "Nom complet", class: "form-label" %>
                <%= f.text_field :name, class: "form-input", placeholder: "Jean Dupont", required: true %>
            </div>
            <div class="form-group">
                <%= f.label :email, "Email", class: "form-label" %>
                <%= f.email_field :email, class: "form-input", placeholder: "votre@email.com", required: true %>
            </div>
            <div class="form-group">
                <%= f.label :location, "Ville", class: "form-label" %>
                <%= f.text_field :location, class: "form-input", placeholder: "Lyon, 3ème arr.", required: true %>
            </div>
            <div class="form-group">
                <%= f.label :bio, "Présentation (optionnel)", class: "form-label" %>
                <%= f.text_area :bio, class: "form-textarea", placeholder: "Décrivez-vous en quelques mots...", rows: 3 %>
            </div>
            <div class="form-group">
                <%= f.label :password, "Mot de passe", class: "form-label" %>
                <%= f.password_field :password, class: "form-input", placeholder: "Min. 8 caractères", required: true %>
            </div>
            <div class="form-group">
                <%= f.label :password_confirmation, "Confirmer le mot de passe", class: "form-label" %>
                <%= f.password_field :password_confirmation, class: "form-input", placeholder: "••••••••", required: true %>
            </div>
            <%= f.submit "Créer mon compte", class: "btn btn-primary btn-full" %>
        <% end %>

        <p class="auth-footer">
            Déjà un compte ?
            <%= link_to "Se connecter", login_path, class: "auth-link" %>
        </p>
    </div>
</div>
