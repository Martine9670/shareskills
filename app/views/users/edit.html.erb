<div class="auth-page">
    <div class="auth-card">
        <h2 class="auth-title">Modifier mon profil</h2>

        <% if @user.errors.any? %>
            <div class="flash flash-alert">
                <% @user.errors.full_messages.each do |msg| %>
                    <p><%= msg %></p>
                <% end %>
            </div>
        <% end %>

        <%= form_with model: @user, url: user_path(@user), method: :patch, multipart: true do |f| %>

            <%# ── Photo de profil ──────────────────────────────────── %>
            <div class="form-group avatar-upload-group">
                <span class="form-label">Photo de profil</span>
                <div class="avatar-upload-row">
                    <img src="<%= @user.avatar_url %>"
                         alt="avatar"
                         class="avatar-preview"
                         id="avatar-preview">
                    <div class="avatar-upload-info">
                        <%= f.file_field :avatar_image,
                            class: "avatar-file-input",
                            id: "avatar-file-input",
                            accept: "image/*" %>
                        <label for="avatar-file-input" class="btn btn-sm avatar-upload-label">
                            📷 Choisir une photo
                        </label>
                        <p class="avatar-hint">JPG, PNG — max 5 Mo</p>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <%= f.label :name, "Nom complet", class: "form-label" %>
                <%= f.text_field :name, class: "form-input", required: true %>
            </div>
            <div class="form-group">
                <%= f.label :email, "Email", class: "form-label" %>
                <%= f.email_field :email, class: "form-input", required: true %>
            </div>
            <div class="form-group">
                <%= f.label :location, "Ville", class: "form-label" %>
                <%= f.text_field :location, class: "form-input", required: true %>
            </div>
            <div class="form-group">
                <%= f.label :bio, "Présentation", class: "form-label" %>
                <%= f.text_area :bio, class: "form-textarea", rows: 4 %>
            </div>
            <div class="form-group">
                <%= f.label :password, "Nouveau mot de passe", class: "form-label" %>
                <%= f.password_field :password, class: "form-input",
                    placeholder: "Laisser vide pour ne pas changer" %>
            </div>
            <div class="form-group">
                <%= f.label :password_confirmation, "Confirmer le mot de passe", class: "form-label" %>
                <%= f.password_field :password_confirmation, class: "form-input",
                    placeholder: "••••••••" %>
            </div>
            <div class="auth-actions">
                <%= f.submit "Enregistrer", class: "btn btn-primary" %>
                <%= link_to "Annuler", dashboard_path, class: "btn" %>
            </div>
        <% end %>
    </div>
</div>

<script>
document.getElementById('avatar-file-input').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
        document.getElementById('avatar-preview').src = ev.target.result;
    };
    reader.readAsDataURL(file);
});
</script>
