<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">
            <div class="logo-icon">S</div>
            <span class="logo-text">ShareSkills</span>
        </div>
        <h2 class="auth-title">Connexion</h2>

        <% if flash[:alert] %>
            <div class="flash flash-alert"><%= flash[:alert] %></div>
        <% end %>

        <%= form_with url: login_path, method: :post do |f| %>
            <div class="form-group">
                <%= f.label :email, "Email", class: "form-label" %>
                <%= f.email_field :email, class: "form-input", placeholder: "votre@email.com", required: true %>
            </div>
            <div class="form-group">
                <%= f.label :password, "Mot de passe", class: "form-label" %>
                <%= f.password_field :password, class: "form-input", placeholder: "••••••••", required: true %>
            </div>
            <%= f.submit "Se connecter", class: "btn btn-primary btn-full" %>
        <% end %>

        <p class="auth-footer">
            Pas encore de compte ?
            <%= link_to "Créer un compte", signup_path, class: "auth-link" %>
        </p>
    </div>
</div>
