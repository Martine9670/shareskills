<div class="inbox-header">
    <h1>Messages</h1>
    <% if @unread_count > 0 %>
        <span class="inbox-badge"><%= @unread_count %> non lu<%= @unread_count > 1 ? "s" : "" %></span>
    <% end %>
</div>

<% if @conversations.any? %>
    <div class="inbox-list">
        <% @conversations.each do |partner| %>
            <% last_msg = Message.conversation_between(current_user, partner).last %>
            <% unread   = Message.unread_for(current_user).where(sender: partner).count %>
            <%= link_to message_path(partner), class: "inbox-item #{'inbox-item--unread' if unread > 0}" do %>
                <img src="<%= partner.avatar_url %>" class="inbox-avatar" alt="">
                <div class="inbox-content">
                    <div class="inbox-name">
                        <%= partner.name %>
                        <% if unread > 0 %>
                            <span class="inbox-badge inbox-badge--sm"><%= unread %></span>
                        <% end %>
                    </div>
                    <div class="inbox-preview"><%= truncate(last_msg.body, length: 60) %></div>
                </div>
                <div class="inbox-date"><%= last_msg.created_at.strftime("%d %b") %></div>
            <% end %>
        <% end %>
    </div>
<% else %>
    <div class="empty-state">
        <div class="empty-icon">✉</div>
        <h3>Aucune conversation</h3>
        <p class="text-muted">Visitez un profil pour envoyer un message.</p>
    </div>
<% end %>
