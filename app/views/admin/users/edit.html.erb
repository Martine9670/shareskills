<div class="admin-header">
    <h1>Modifier <%= @user.name %></h1>
    <%= link_to "← Retour", admin_users_path, class: "btn btn-sm" %>
</div>

<div class="admin-form-card">
    <% if @user.errors.any? %>
        <div class="flash flash-alert">
            <% @user.errors.full_messages.each do |msg| %>
                <p><%= msg %></p>
            <% end %>
        </div>
    <% end %>

    <%= form_with model: [:admin, @user] do |f| %>
        <div class="form-group">
            <%= f.label :name, "Nom", class: "form-label" %>
            <%= f.text_field :name, class: "form-input" %>
        </div>
        <div class="form-group">
            <%= f.label :email, "Email", class: "form-label" %>
            <%= f.email_field :email, class: "form-input" %>
        </div>
        <div class="form-group">
            <%= f.label :location, "Ville", class: "form-label" %>
            <%= f.text_field :location, class: "form-input" %>
        </div>
        <div class="form-group">
            <%= f.label :bio, "Bio", class: "form-label" %>
            <%= f.text_area :bio, class: "form-textarea", rows: 3 %>
        </div>
        <div class="form-group">
            <%= f.label :credits_minutes, "Crédits (minutes)", class: "form-label" %>
            <%= f.number_field :credits_minutes, class: "form-input", min: 0 %>
        </div>
        <div class="form-group form-check">
            <%= f.check_box :is_admin, class: "form-checkbox" %>
            <%= f.label :is_admin, "Administrateur", class: "form-label" %>
        </div>
        <%= f.submit "Enregistrer", class: "btn btn-primary" %>
    <% end %>
</div>
