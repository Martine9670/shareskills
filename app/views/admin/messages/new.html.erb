<div class="admin-header">
    <h1>Envoyer un message</h1>
</div>

<div class="admin-form-card">
    <%= form_with url: admin_messages_path, method: :post do |f| %>

        <!-- Type de message -->
        <div class="admin-field">
            <label class="admin-label">Type de message</label>
            <div class="admin-radio-group">
                <label class="admin-radio">
                    <input type="radio" name="message_type" value="contact" checked
                           onchange="toggleMessageType(this.value)">
                    Contacter un utilisateur
                </label>
                <label class="admin-radio">
                    <input type="radio" name="message_type" value="introduce"
                           onchange="toggleMessageType(this.value)">
                    Mettre deux utilisateurs en relation
                </label>
            </div>
        </div>

        <!-- Contacter un user -->
        <div id="section-contact">
            <div class="admin-field">
                <label class="admin-label">Destinataire</label>
                <select name="user_id" class="admin-input">
                    <% @users.each do |user| %>
                        <option value="<%= user.id %>" <%= 'selected' if user.id.to_s == @preselected_user_id.to_s %>>
                            <%= user.name %> — <%= user.email %>
                        </option>
                    <% end %>
                </select>
            </div>
            <div class="admin-field">
                <label class="admin-label">Sujet</label>
                <%= f.text_field :subject, class: "admin-input", placeholder: "Sujet du message" %>
            </div>
        </div>

        <!-- Mettre en relation -->
        <div id="section-introduce" style="display: none;">
            <div class="admin-field">
                <label class="admin-label">Premier utilisateur</label>
                <select name="user1_id" class="admin-input">
                    <% @users.each do |user| %>
                        <option value="<%= user.id %>"><%= user.name %> — <%= user.email %></option>
                    <% end %>
                </select>
            </div>
            <div class="admin-field">
                <label class="admin-label">Deuxième utilisateur</label>
                <select name="user2_id" class="admin-input">
                    <% @users.each do |user| %>
                        <option value="<%= user.id %>"><%= user.name %> — <%= user.email %></option>
                    <% end %>
                </select>
            </div>
        </div>

        <!-- Message commun -->
        <div class="admin-field">
            <label class="admin-label">Message</label>
            <%= f.text_area :message, class: "admin-input", rows: 6,
                placeholder: "Votre message..." %>
        </div>

        <div class="admin-form-actions">
            <%= link_to "Annuler", admin_users_path, class: "btn" %>
            <%= f.submit "Envoyer", class: "btn btn-primary" %>
        </div>
    <% end %>
</div>

<script>
function toggleMessageType(type) {
    document.getElementById('section-contact').style.display   = type === 'contact'   ? '' : 'none';
    document.getElementById('section-introduce').style.display = type === 'introduce' ? '' : 'none';
}
</script>
