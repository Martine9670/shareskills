<% if skill.errors.any? %>
    <div class="flash flash-alert">
        <% skill.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
        <% end %>
    </div>
<% end %>

<div class="admin-form-card">
    <%= form_with model: [:admin, skill] do |f| %>
        <div class="form-group">
            <%= f.label :name, "Nom", class: "form-label" %>
            <%= f.text_field :name, class: "form-input", placeholder: "ex: JavaScript" %>
        </div>
        <div class="form-group">
            <%= f.label :category, "Catégorie", class: "form-label" %>
            <%= f.select :category,
                Skill::CATEGORIES.map { |k, v| [v, k] },
                { include_blank: "Choisir une catégorie" },
                class: "form-select" %>
        </div>
        <%= f.submit "Enregistrer", class: "btn btn-primary" %>
        <%= link_to "Annuler", admin_skills_path, class: "btn" %>
    <% end %>
</div>
